# ===============================
# MarkeTTalento - Configuración
# ===============================

# Base de datos PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/markettalento

# Configuración API
API_HOST=0.0.0.0
API_PORT=8000

# Modelo YOLOv8 (scratch = entrenar, o ruta a modelo .pt)
YOLO_MODEL=yolov8n.pt

# Logging
LOG_LEVEL=INFO

# Streamlit
STREAMLIT_PORT=8501