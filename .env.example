# ===============================
# MarkeTTalento - Configuración
# ===============================

# Base de datos (SQLite o PostgreSQL)
DATABASE_URL=sqlite:///markettalento.db
# DATABASE_URL=postgresql://postgres:password@localhost:5432/markettalento

# Configuración API
API_HOST=127.0.0.1
API_PORT=8002

# Modelo YOLOv8
YOLO_MODEL=yolov8n.pt

# Logging
LOG_LEVEL=INFO

# Streamlit
STREAMLIT_PORT=8501